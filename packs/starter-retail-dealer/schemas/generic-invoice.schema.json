{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_date",
    "location_id",
    "seller_legal_entity_id",
    "customer_party_id",
    "currency_code",
    "lines"
  ],
  "properties": {
    "document_date": {
      "type": "string",
      "format": "date"
    },
    "location_id": {
      "type": "string",
      "format": "uuid"
    },
    "seller_legal_entity_id": {
      "type": "string",
      "format": "uuid"
    },
    "customer_party_id": {
      "type": "string",
      "format": "uuid"
    },
    "inventory_unit_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "currency_code": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "description",
          "quantity",
          "unit_amount_minor"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "quantity": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "unit_amount_minor": {
            "type": "integer"
          },
          "tax_classification": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "tax_profile_version_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "notes": {
      "type": "string",
      "maxLength": 10000
    }
  }
}
