{
  "name": "@vynlo/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.build.json && node build.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "node ../../scripts/run-with-local-env.mjs node --import tsx --watch src/index.ts",
    "health": "tsx src/health-command.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vynlo/jobs": "workspace:*",
    "@vynlo/observability": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "esbuild": "0.28.1"
  }
}
