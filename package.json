{
  "name": "vynlo",
  "version": "0.0.0",
  "private": true,
  "description": "Vynlo modular-monolith workspace",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.13.0"
  },
  "scripts": {
    "build": "pnpm --recursive --if-present build",
    "check:boundaries": "node scripts/check-package-boundaries.mjs",
    "check:deps": "pnpm audit --audit-level high",
    "check:supabase": "node scripts/check-stage0-db-foundation.mjs",
    "check:supabase:runtime": "node scripts/check-stage0-db-runtime.mjs",
    "check:markdown": "python scripts/check_markdown_links.py",
    "check:openapi": "redocly lint contracts/openapi.v1.yaml",
    "check:secrets": "secretlint \"**/*\"",
    "check:spec": "python scripts/validate_spec.py .",
    "clean": "pnpm --recursive --if-present clean",
    "db:migrate": "supabase migration up",
    "db:reset": "supabase db reset",
    "dev": "pnpm --parallel --filter @vynlo/web --filter @vynlo/worker dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "supabase:reset": "supabase db reset",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "seed:synthetic": "supabase db reset",
    "test": "vitest run",
    "test:api": "pnpm check:openapi",
    "test:config": "pnpm check:spec",
    "test:db": "pnpm check:supabase",
    "test:docs": "pnpm check:markdown",
    "test:e2e": "playwright test",
    "test:security": "pnpm check:boundaries && pnpm check:secrets",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "validate": "pnpm verify && pnpm check:deps",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm check:spec && pnpm check:openapi && pnpm check:markdown && pnpm check:boundaries && pnpm check:secrets && pnpm build",
    "worker:health": "pnpm --filter @vynlo/worker health"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@redocly/cli": "2.40.0",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.4",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-config-next": "16.2.11",
    "prettier": "3.9.6",
    "secretlint": "13.0.4",
    "supabase": "2.109.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
