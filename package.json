{
  "name": "vynlo",
  "version": "0.0.0",
  "private": true,
  "description": "Vynlo modular-monolith workspace",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.13.0"
  },
  "scripts": {
    "build": "pnpm --recursive --if-present build",
    "check:boundaries": "node scripts/check-package-boundaries.mjs",
    "check:deps": "pnpm audit --audit-level high",
    "check:supabase": "node scripts/check-m1-db-foundation.mjs",
    "check:supabase:runtime": "node scripts/check-m1-db-runtime.mjs",
    "check:ui-system": "node scripts/check-ui-system.mjs",
    "check:markdown": "python scripts/check_markdown_links.py",
    "check:openapi": "node --test scripts/check-m3-openapi-contract.test.mjs scripts/check-m4-openapi-contract.test.mjs && node scripts/check-m3-openapi-contract.mjs && node scripts/check-m4-openapi-contract.mjs && redocly lint contracts/openapi.v1.yaml",
    "check:secrets": "secretlint \"**/*\"",
    "check:spec": "python scripts/validate_spec.py .",
    "clean": "pnpm --recursive --if-present clean",
    "db:migrate": "supabase migration up",
    "db:reset": "supabase db reset",
    "dev": "pnpm --parallel --filter @vynlo/web --filter @vynlo/worker dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "supabase:reset": "supabase db reset",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "seed:synthetic": "supabase db reset",
    "test": "vitest run",
    "test:api": "pnpm check:openapi",
    "test:config": "pnpm check:spec",
    "test:db": "pnpm check:supabase && pnpm exec supabase test db",
    "test:docs": "pnpm check:markdown",
    "test:e2e": "playwright test",
    "test:security": "pnpm check:boundaries && pnpm check:secrets",
    "test:stock-concurrency": "node scripts/check-stock-allocation-concurrency.mjs",
    "test:ui-system": "node --test scripts/check-ui-system.test.mjs",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "validate": "pnpm verify && pnpm check:deps",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm check:ui-system && pnpm test:ui-system && pnpm test && pnpm check:spec && pnpm check:openapi && pnpm check:markdown && pnpm check:boundaries && pnpm check:secrets && pnpm check:supabase && pnpm build",
    "worker:health": "pnpm --filter @vynlo/worker health"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@redocly/cli": "2.39.0",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "@types/node": "26.1.1",
    "@types/pg": "8.15.5",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "pg": "8.16.3",
    "prettier": "3.9.5",
    "secretlint": "13.0.2",
    "supabase": "2.109.1",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
