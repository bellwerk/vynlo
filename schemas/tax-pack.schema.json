{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.vynlo.example/tax-pack/1.1.0",
  "title": "Vynlo Tax Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "key",
    "version",
    "jurisdiction",
    "contexts",
    "effective_from",
    "effective_to",
    "sources",
    "rules",
    "golden_tests",
    "activation_status",
    "approval_refs"
  ],
  "properties": {
    "key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,127}$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "jurisdiction": {
      "type": "string",
      "pattern": "^[A-Z]{2}(?:-[A-Z0-9]{1,3})?$"
    },
    "contexts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]{0,127}$"
      }
    },
    "effective_from": {
      "type": "string",
      "format": "date"
    },
    "effective_to": {
      "oneOf": [
        { "type": "string", "format": "date" },
        { "type": "null" }
      ]
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": { "$ref": "#/$defs/source" }
    },
    "rules": { "$ref": "#/$defs/rules" },
    "golden_tests": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^tests/(?!\\.\\.(?:/|$))(?!.*\\/\\.\\.(?:\\/|$))[A-Za-z0-9._/-]+\\.json$"
      }
    },
    "activation_status": {
      "enum": ["draft", "validated", "test_passed", "approved", "active", "retired"]
    },
    "approval_refs": {
      "type": "array",
      "maxItems": 128,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 200 }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "activation_status": { "enum": ["approved", "active"] }
        },
        "required": ["activation_status"]
      },
      "then": {
        "properties": {
          "approval_refs": { "minItems": 1 }
        }
      }
    }
  ],
  "$defs": {
    "machineKey": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,127}$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "authority", "url", "accessed_on"],
      "properties": {
        "key": { "$ref": "#/$defs/machineKey" },
        "authority": { "type": "string", "minLength": 1, "maxLength": 200 },
        "url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "accessed_on": { "type": "string", "format": "date" }
      }
    },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "rounding",
        "taxes",
        "trade_in",
        "unsupported_without_override"
      ],
      "properties": {
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "rounding": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "scale", "stage"],
          "properties": {
            "mode": { "enum": ["HALF_UP", "HALF_EVEN", "DOWN", "UP"] },
            "scale": { "type": "integer", "minimum": 0, "maximum": 6 },
            "stage": { "const": "tax_total_per_tax_type" }
          }
        },
        "taxes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": { "$ref": "#/$defs/tax" }
        },
        "trade_in": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "strategy",
            "requires_explicit_eligibility_inputs",
            "lien_payoff_is_not_automatically_tax_credit"
          ],
          "properties": {
            "strategy": {
              "const": "conditional_credit_reduces_taxable_consideration"
            },
            "requires_explicit_eligibility_inputs": { "const": true },
            "lien_payoff_is_not_automatically_tax_credit": { "const": true }
          }
        },
        "unsupported_without_override": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/machineKey" }
        }
      }
    },
    "tax": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "labels", "rate", "taxable_base", "source_ref"],
      "properties": {
        "key": {
          "allOf": [
            { "$ref": "#/$defs/machineKey" },
            {
              "not": {
                "enum": [
                  "eligible_taxable_consideration",
                  "non_taxable_fees",
                  "total_tax",
                  "net_cash_consideration_before_payments"
                ]
              }
            }
          ]
        },
        "labels": {
          "type": "object",
          "additionalProperties": false,
          "required": ["en", "fr"],
          "properties": {
            "en": { "type": "string", "minLength": 1, "maxLength": 100 },
            "fr": { "type": "string", "minLength": 1, "maxLength": 100 }
          }
        },
        "rate": {
          "type": "string",
          "pattern": "^(?:0(?:\\.\\d{1,12})?|1(?:\\.0+)?)$"
        },
        "taxable_base": { "const": "eligible_taxable_consideration" },
        "gst_included_in_base": { "type": "boolean" },
        "source_ref": { "$ref": "#/$defs/machineKey" }
      }
    }
  }
}
