{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.vynlo.example/workspace-config-package/1.0.0",
  "title": "Vynlo Workspace Configuration Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "package",
    "compatibility",
    "entitlements",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "name",
        "version",
        "visibility",
        "purpose"
      ],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,62}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "visibility": {
          "enum": ["public", "private"]
        },
        "purpose": {
          "enum": ["seed", "migration", "export", "demo"]
        },
        "workspace_key": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,62}$"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform_schema"],
      "properties": {
        "platform_schema": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "entitlements": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]{1,63}$"
      },
      "uniqueItems": true
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "legal_entities": {"$ref": "#/$defs/pathList"},
        "locations": {"$ref": "#/$defs/pathList"},
        "roles": {"$ref": "#/$defs/pathList"},
        "fields": {"$ref": "#/$defs/pathList"},
        "workflows": {"$ref": "#/$defs/pathList"},
        "numbering": {"$ref": "#/$defs/pathList"},
        "documents": {"$ref": "#/$defs/pathList"},
        "calculations": {"$ref": "#/$defs/pathList"},
        "exports": {"$ref": "#/$defs/pathList"},
        "integrations": {"$ref": "#/$defs/pathList"},
        "migration": {"$ref": "#/$defs/pathList"},
        "tests": {"$ref": "#/$defs/pathList"}
      }
    },
    "activation_gates": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]{1,95}$"
      },
      "uniqueItems": true,
      "default": []
    }
  },
  "$defs": {
    "pathList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
