{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.vynlo.example/workflow/1.0.0",
  "title": "Vynlo Workflow Definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "entity_type",
        "version",
        "initial_state",
        "states",
        "transitions"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "entity_type": {
          "type": "string"
        },
        "deal_type": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "initial_state": {
          "type": "string"
        },
        "states": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/state"
          }
        },
        "transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transition"
          }
        },
        "invariants": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "category",
        "labels",
        "flags"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "category": {
          "enum": [
            "draft",
            "active",
            "pending",
            "closed",
            "archived"
          ]
        },
        "labels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string"
          }
        },
        "flags": {
          "type": "object",
          "additionalProperties": {
            "type": "boolean"
          }
        },
        "order": {
          "type": "integer"
        }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "from",
        "to",
        "permission"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "permission": {
          "type": "string"
        },
        "guard": {
          "type": "string"
        },
        "reason_required": {
          "type": "boolean"
        },
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "effects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
