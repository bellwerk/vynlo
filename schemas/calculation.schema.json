{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.vynlo.example/calculation/1.0.0",
  "title": "Vynlo Calculation Definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "key",
    "version",
    "status",
    "input_schema",
    "outputs",
    "rounding",
    "fixtures"
  ],
  "properties": {
    "key": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-_]{1,127}$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "enum": [
        "draft",
        "test_passed",
        "approved",
        "active",
        "retired"
      ]
    },
    "input_schema": {
      "type": "object"
    },
    "outputs": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/expression"
      }
    },
    "rounding": {
      "type": "object"
    },
    "fixtures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "$defs": {
    "expression": {
      "oneOf": [
        {
          "$ref": "#/$defs/constant"
        },
        {
          "$ref": "#/$defs/field"
        },
        {
          "$ref": "#/$defs/arithmetic"
        },
        {
          "$ref": "#/$defs/round"
        },
        {
          "$ref": "#/$defs/compare"
        },
        {
          "$ref": "#/$defs/if"
        },
        {
          "$ref": "#/$defs/coalesce"
        },
        {
          "$ref": "#/$defs/sum_rows"
        },
        {
          "$ref": "#/$defs/tax_pack"
        },
        {
          "$ref": "#/$defs/amortized_payment"
        },
        {
          "$ref": "#/$defs/amortization_schedule"
        },
        {
          "$ref": "#/$defs/date_add"
        }
      ]
    },
    "constant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "value"
      ],
      "properties": {
        "op": {
          "const": "constant"
        },
        "value": {}
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "path"
      ],
      "properties": {
        "op": {
          "const": "field"
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "arithmetic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "args"
      ],
      "properties": {
        "op": {
          "enum": [
            "add",
            "subtract",
            "multiply",
            "divide",
            "min",
            "max",
            "sum",
            "abs"
          ]
        },
        "args": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/expression"
          },
          "minItems": 1,
          "maxItems": 1000
        }
      }
    },
    "round": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "value",
        "scale",
        "mode"
      ],
      "properties": {
        "op": {
          "const": "round"
        },
        "value": {
          "$ref": "#/$defs/expression"
        },
        "scale": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8
        },
        "mode": {
          "enum": [
            "half_up",
            "half_even",
            "down",
            "up"
          ]
        }
      }
    },
    "compare": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "left",
        "right"
      ],
      "properties": {
        "op": {
          "enum": [
            "eq",
            "ne",
            "lt",
            "lte",
            "gt",
            "gte"
          ]
        },
        "left": {
          "$ref": "#/$defs/expression"
        },
        "right": {
          "$ref": "#/$defs/expression"
        }
      }
    },
    "if": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "condition",
        "then",
        "else"
      ],
      "properties": {
        "op": {
          "const": "if"
        },
        "condition": {
          "$ref": "#/$defs/expression"
        },
        "then": {
          "$ref": "#/$defs/expression"
        },
        "else": {
          "$ref": "#/$defs/expression"
        }
      }
    },
    "coalesce": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "args"
      ],
      "properties": {
        "op": {
          "const": "coalesce"
        },
        "args": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/expression"
          },
          "minItems": 1
        }
      }
    },
    "sum_rows": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "rows_path",
        "value_path"
      ],
      "properties": {
        "op": {
          "const": "sum_rows"
        },
        "rows_path": {
          "type": "string"
        },
        "value_path": {
          "type": "string"
        },
        "where": {
          "type": [
            "object",
            "null"
          ]
        }
      }
    },
    "tax_pack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "context",
        "inputs",
        "output"
      ],
      "properties": {
        "op": {
          "const": "tax_pack"
        },
        "context": {
          "type": "string"
        },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/expression"
          }
        },
        "output": {
          "type": "string"
        }
      }
    },
    "amortized_payment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "principal_minor",
        "annual_rate_bps",
        "periods_per_year",
        "number_of_periods",
        "rounding"
      ],
      "properties": {
        "op": {
          "const": "amortized_payment"
        },
        "principal_minor": {
          "$ref": "#/$defs/expression"
        },
        "annual_rate_bps": {
          "$ref": "#/$defs/expression"
        },
        "periods_per_year": {
          "$ref": "#/$defs/expression"
        },
        "number_of_periods": {
          "$ref": "#/$defs/expression"
        },
        "rounding": {
          "type": "object",
          "required": [
            "mode",
            "minor_unit"
          ],
          "properties": {
            "mode": {
              "enum": [
                "half_up",
                "half_even",
                "down",
                "up"
              ]
            },
            "minor_unit": {
              "type": "integer",
              "minimum": 0,
              "maximum": 6
            }
          }
        }
      }
    },
    "amortization_schedule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "principal_minor",
        "annual_rate_bps",
        "periods_per_year",
        "number_of_periods",
        "first_due_date",
        "period_days",
        "payment_minor",
        "rounding"
      ],
      "properties": {
        "op": {
          "const": "amortization_schedule"
        },
        "principal_minor": {
          "$ref": "#/$defs/expression"
        },
        "annual_rate_bps": {
          "$ref": "#/$defs/expression"
        },
        "periods_per_year": {
          "$ref": "#/$defs/expression"
        },
        "number_of_periods": {
          "$ref": "#/$defs/expression"
        },
        "first_due_date": {
          "$ref": "#/$defs/expression"
        },
        "period_days": {
          "$ref": "#/$defs/expression"
        },
        "payment_minor": {
          "$ref": "#/$defs/expression"
        },
        "rounding": {
          "type": "object",
          "required": [
            "mode",
            "minor_unit",
            "final_payment_adjustment"
          ],
          "properties": {
            "mode": {
              "enum": [
                "half_up",
                "half_even",
                "down",
                "up"
              ]
            },
            "minor_unit": {
              "type": "integer",
              "minimum": 0,
              "maximum": 6
            },
            "final_payment_adjustment": {
              "const": true
            }
          }
        }
      }
    },
    "date_add": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "op",
        "date",
        "days"
      ],
      "properties": {
        "op": {
          "const": "date_add_days"
        },
        "date": {
          "$ref": "#/$defs/expression"
        },
        "days": {
          "$ref": "#/$defs/expression"
        }
      }
    }
  }
}
