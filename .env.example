# Vynlo local/development example. Never commit real secrets or tenant credentials.

APP_ENV=local
NEXT_PUBLIC_APP_NAME=Vynlo
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000/api/v1

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

CREDENTIAL_ENCRYPTION_KEY=
AUDIT_HASH_KEY=

AUTH_SESSION_MAX_DAYS=14
STEP_UP_MAX_AGE_MINUTES=15

WORKER_POLL_INTERVAL_MS=1000
WORKER_CONCURRENCY=4
JOB_MAX_ATTEMPTS=8
PDF_RENDERER=playwright
MANAGED_STORAGE_PROVIDER=supabase

MEDIA_MASTER_MAX_EDGE_PX=2560
MEDIA_WEB_MAX_WIDTH_PX=1080
MEDIA_THUMBNAIL_WIDTHS=320,640
MEDIA_RAW_RETENTION_DAYS=7

SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info

TRANSACTIONAL_EMAIL_PROVIDER=
TRANSACTIONAL_EMAIL_API_KEY=

# Tenant-specific Drive, Webflow, tax assignment, formulas, document templates,
# GoCardless, Gmail, folder IDs, and OAuth refresh tokens belong in encrypted
# runtime workspace configuration—not in global environment variables.
