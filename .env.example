# Vynlo local/development example. Never commit real secrets or tenant credentials.
# Copy to .env.local for local use only. Development, staging, and production
# use separate secret stores, Supabase projects, provider connections, and URLs.
# Never promote a local environment file between environments.

APP_ENV=local
NEXT_PUBLIC_APP_NAME=Vynlo
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000/api/v1

NEXT_PUBLIC_SUPABASE_URL=
# Preferred public browser/server key. The legacy anon JWT remains supported
# during project migration; configure only public keys in NEXT_PUBLIC_* values.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

CREDENTIAL_ENCRYPTION_KEY=
AUDIT_HASH_KEY=

AUTH_SESSION_MAX_DAYS=14
STEP_UP_MAX_AGE_MINUTES=15

# Server-only worker configuration. The service-role credential must never be
# exposed through NEXT_PUBLIC_* or copied into a browser environment.
VYNLO_APP_URL=http://localhost:3000
VYNLO_SUPABASE_URL=http://127.0.0.1:54321
VYNLO_SUPABASE_SERVICE_ROLE_KEY=
VYNLO_WORKER_ID=local-worker-1
VYNLO_PREVIEW_BUCKET=document-previews
VYNLO_AUTH_INVITE_TIMEOUT_MS=10000
VYNLO_WORKER_LEASE_SECONDS=60
VYNLO_WORKER_HEARTBEAT_INTERVAL_MS=20000
VYNLO_WORKER_BATCH_SIZE=10
VYNLO_WORKER_POLL_INTERVAL_MS=1000
VYNLO_WORKER_ERROR_BACKOFF_BASE_MS=1000
VYNLO_WORKER_ERROR_BACKOFF_MAX_MS=30000

PDF_RENDERER=playwright
MANAGED_STORAGE_PROVIDER=supabase

MEDIA_MASTER_MAX_EDGE_PX=2560
MEDIA_WEB_MAX_WIDTH_PX=1080
MEDIA_THUMBNAIL_WIDTHS=320,640
MEDIA_RAW_RETENTION_DAYS=7

SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info

TRANSACTIONAL_EMAIL_PROVIDER=
TRANSACTIONAL_EMAIL_API_KEY=

# Tenant-specific Drive, Webflow, tax assignment, formulas, document templates,
# GoCardless, Gmail, folder IDs, and OAuth refresh tokens belong in encrypted
# runtime workspace configuration—not in global environment variables.
