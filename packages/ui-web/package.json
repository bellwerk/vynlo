    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "lucide-react": "1.24.0",
    "next-themes": "0.4.6",
    "radix-ui": "1.6.2",
    "react": "19.2.7",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17"
  }
}
